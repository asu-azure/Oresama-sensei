# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Restart `npm run dev` after editing — Next reads env only at startup.

# --- Supabase (project URL + anon/publishable key) ---
# Both are safe to expose to the browser (NEXT_PUBLIC_*). Find them in the
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key

# --- AI models (server-only secrets) ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...

# --- Optional: online image search for knowledge items (v3.9) ---
# If unset, the feature falls back to Openverse (no key needed). Get a free
# key at https://pixabay.com/api/docs/
PIXABAY_KEY=

# --- Optional: Supabase MCP for AI agents (NOT used by the Next.js app) ---
# This is read by Claude Code from your shell/system environment, NOT from
# .env.local. Set it as a real environment variable instead, e.g. on Windows:
#   setx SUPABASE_ACCESS_TOKEN "<token>"
# Create the token at Supabase dashboard → Account → Access Tokens. See the
# "Supabase MCP" section in CLAUDE.md.
# SUPABASE_ACCESS_TOKEN=sbp_...
